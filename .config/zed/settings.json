// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "button": false,
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4.5",
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-6",
      "effort": "max",
      "enable_thinking": true,
    },
    "default_profile": "ask",
    "dock": "left",
    "enable_feedback": false,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4.6",
      "effort": "max",
      "enable_thinking": true,
    },
    "inline_alternatives": [
      {
        "provider": "zed.dev",
        "model": "claude-opus-4.6",
        "effort": "max",
        "enable_thinking": true,
      },
    ],
    "message_editor_min_lines": 8,
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": true,
    "profiles": {
      "ask": {
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-6",
          "effort": "max",
          "enable_thinking": true,
        },
        "name": "Ask",
        "context_servers": {
          "DuckDB (read-only)": {
            "tools": {
              "list_tables": true,
              "list_databases": true,
              "list_columns": true,
              "execute_query": true,
            },
          },
          "Context7": {
            "tools": {
              "query-docs": true,
              "get-library-docs": true,
              "resolve-library-id": true,
            },
          },
          "DeepWiki": {
            "tools": {
              "read_wiki_structure": true,
              "read_wiki_contents": true,
              "ask_question": true,
            },
          },
          "Sentry": {
            "tools": {
              "find_organizations": true,
              "find_projects": true,
              "analyze_issue_with_seer": false,
              "get_doc": true,
              "get_event_attachment": true,
              "get_issue_details": true,
              "get_issue_tag_values": true,
              "get_trace_details": true,
              "search_docs": true,
              "search_events": true,
              "search_issue_events": true,
              "search_issues": true,
              "whoami": true,
            },
          },
          "Sequential thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
        },
        "enable_all_context_servers": false,
        "tools": {
          "terminal": false,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true,
        },
      },
      "minimal": {
        "default_model": {
          "provider": "zed.dev",
          "model": "gpt-5.4-pro",
          "effort": "xhigh",
          "enable_thinking": true,
        },
        "name": "Minimal",
        "tools": {},
        "enable_all_context_servers": false,
      },
      "sequential_thinking": {
        "tools": {
          "spawn_agent": true,
          "diagnostics": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "web_search": true,
          "open": true,
          "now": true,
          "fetch": true,
        },
        "name": "Sequential thinking",
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-6",
          "effort": "max",
          "enable_thinking": true,
        },
        "enable_all_context_servers": true,
      },
      "triage": {
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-6",
          "effort": "max",
          "enable_thinking": true,
        },
        "name": "Triage",
        "context_servers": {
          "DuckDB (read-only)": {
            "tools": {
              "list_tables": true,
              "list_databases": true,
              "list_columns": true,
              "execute_query": true,
            },
          },
          "Context7": {
            "tools": {
              "query-docs": true,
              "get-library-docs": true,
              "resolve-library-id": true,
            },
          },
          "DeepWiki": {
            "tools": {
              "read_wiki_structure": true,
              "read_wiki_contents": true,
              "ask_question": true,
            },
          },
          "Sentry": {
            "tools": {
              "find_organizations": true,
              "find_projects": true,
              "analyze_issue_with_seer": false,
              "get_doc": true,
              "get_event_attachment": true,
              "get_issue_details": true,
              "get_issue_tag_values": true,
              "get_trace_details": true,
              "search_docs": true,
              "search_events": true,
              "search_issue_events": true,
              "search_issues": true,
              "whoami": true,
            },
          },
          "Sequential thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
        },
        "enable_all_context_servers": false,
        "tools": {
          "terminal": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true,
        },
      },
      "write": {
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-6",
          "effort": "max",
          "enable_thinking": true,
        },
        "name": "Write",
        "enable_all_context_servers": true,
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
        },
      },
    },
    "show_turn_stats": true,
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "mcp:Context7:get-library-docs": { "default": "allow" },
        "mcp:Context7:query-docs": { "default": "allow" },
        "mcp:Context7:resolve-library-id": { "default": "allow" },
        "mcp:DeepWiki:ask_question": { "default": "allow" },
        "mcp:DeepWiki:read_wiki_contents": { "default": "allow" },
        "mcp:DeepWiki:read_wiki_structure": { "default": "allow" },
        "mcp:Sequential thinking:sequentialthinking": { "default": "allow" },
        "diagnostics": { "default": "allow" },
        "now": { "default": "allow" },
        "terminal": {
          "always_allow": [
            { "pattern": "^gh\\s+issue\\s+(list|view|status)(\\s|$)" },
            { "pattern": "^gh\\s+pr\\s+(list|view|status|checks|diff)(\\s|$)" },
            {
              "pattern": "^gh\\s+search\\s+(issues|prs|repos|commits|code)(\\s|$)",
            },
            { "pattern": "^gh\\s+repo\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+run\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+workflow\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+release\\s+(list|view)(\\s|$)" },
            {
              "pattern": "^gh\\s+project\\s+(list|view|field-list|item-list)(\\s|$)",
            },
            { "pattern": "^gh\\s+ruleset\\s+(list|view|check)(\\s|$)" },
            { "pattern": "^gh\\s+label\\s+list(\\s|$)" },
            { "pattern": "^gh\\s+cache\\s+list(\\s|$)" },
            { "pattern": "^gh\\s+status(\\s|$)" },
          ],
        },
        "thinking": { "default": "allow" },
      },
    },
  },
  "agent_servers": {
    "auggie": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "cline": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
    "factory-droid": {
      "type": "registry",
    },
    "kimi": {
      "type": "registry",
    },
    "mistral-vibe": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "qwen-code": {
      "type": "registry",
    },
  },
  "audio": {
    "experimental.rodio_audio": false,
  },
  "auto_update": false,
  "buffer_font_size": 14,
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_weight": 500.0,
  "calls": {
    "mute_on_join": true,
  },
  "collaboration_panel": {
    "default_width": 300.0,
    "button": false,
  },
  "colorize_brackets": true,
  "context_servers": {
    "Context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
    },
    "DeepWiki": {
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "Sentry": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.sentry.dev/mcp"],
    },
    // An MCP server implementation that provides a tool for dynamic and reflective problem-solving through a structured thinking process.
    "Sequential thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
    },
  },
  "cursor_shape": "block",
  "debugger": {
    "button": false,
    "format_dap_log_messages": true,
    "log_dap_communications": true,
  },
  "diagnostics": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [],
    "mode": "subtle",
  },
  "fast_scroll_sensitivity": 10.0,
  "file_types": {
    "Git Ignore": [".dockerignore", ".prettierignore"],
  },
  "git_hosting_providers": [],
  "git_panel": {
    "button": false,
    "scrollbar": {
      "show": "system",
    },
    "show_count_badge": true,
    "tree_view": true,
  },
  "hover_popover_delay": 50,
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Light Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)",
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "active_line_width": 3,
  },
  "language_models": {
    "openai_compatible": {
      "LiteLLM": {
        "api_url": "http://localhost:4000/v1",
        "available_models": [
          {
            "name": "us.anthropic.claude-opus-4-6-v1",
            "display_name": "Claude Opus 4.6 (Bedrock via LiteLLM)",
            "max_tokens": 1000000,
            "max_output_tokens": 128000,
            "max_completion_tokens": 128000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },
  "languages": {
    "Astro": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "language_servers": ["eslint", "..."],
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
    "Markdown": {
      "format_on_save": "on",
      "remove_trailing_whitespace_on_save": false,
      "prettier": {
        "allowed": true,
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "templ": "html",
        },
        "experimental": {
          "classRegex": ["class=\"([^\"]*)\"", "className=\"([^\"]*)\""],
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
  },
  "minimap": {
    "display_in": "active_editor",
    "show": "auto",
  },
  "notification_panel": {
    "button": false,
    "dock": "left",
  },
  "outline_panel": {
    "button": false,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "project_panel": {
    "button": false,
    "default_width": 300,
    "dock": "right",
    "scrollbar": {
      "show": "system",
    },
    "starts_open": false,
  },
  "redact_private_values": true,
  "scroll_sensitivity": 1.5,
  "search": {
    "button": false,
  },
  "semantic_tokens": "combined",
  "show_whitespaces": "selection",
  "soft_wrap": "none",
  "ssh_connections": [
    {
