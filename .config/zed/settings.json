// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "button": false,
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5",
    },
    "default_model": {
      "effort": "max",
      "speed": "standard",
      "provider": "zed.dev",
      "model": "claude-opus-4-8",
      "enable_thinking": true,
    },
    "default_profile": "ask",
    "enable_feedback": false,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4.6",
      "effort": "max",
      "enable_thinking": true,
    },
    "inline_alternatives": [
      {
        "provider": "zed.dev",
        "model": "claude-opus-4.8",
        "effort": "max",
        "enable_thinking": true,
      },
    ],
    "thread_summary_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5",
    },
    "limit_content_width": false,
    "message_editor_min_lines": 8,
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": "always",
    "profiles": {
      "ask": {
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-8",
          "effort": "max",
          "enable_thinking": true,
        },
        "name": "Ask",
        "context_servers": {
          "Context7": {
            "tools": {
              "query-docs": true,
              "get-library-docs": true,
              "resolve-library-id": true,
            },
          },
          "DeepWiki": {
            "tools": {
              "read_wiki_structure": true,
              "read_wiki_contents": true,
              "ask_question": true,
            },
          },
          "fff": {
            "tools": {
              "multi_grep": true,
              "grep": true,
              "find_files": true,
            },
          },
          "Parallel": {
            "tools": {
              "web_fetch": true,
              "web_search": true,
            },
          },
          "Sentry": {
            "tools": {
              "find_organizations": true,
              "find_projects": true,
              "analyze_issue_with_seer": false,
              "get_doc": true,
              "get_event_attachment": true,
              "get_issue_details": true,
              "get_issue_tag_values": true,
              "get_trace_details": true,
              "search_docs": true,
              "search_events": true,
              "search_issue_events": true,
              "search_issues": true,
              "whoami": true,
            },
          },
          "Sequential thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
        },
        "enable_all_context_servers": false,
        "tools": {
          "diagnostics": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "open": true,
          "project_notifications": false,
          "read_file": true,
          "search_web": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
        },
      },
      "minimal": {
        "default_model": {
          "provider": "zed.dev",
          "model": "gpt-5.4-pro",
          "effort": "xhigh",
          "enable_thinking": true,
        },
        "name": "Minimal",
        "tools": {},
        "enable_all_context_servers": false,
      },
      "write": {
        "default_model": {
          "provider": "zed.dev",
          "model": "claude-opus-4-8",
          "effort": "max",
          "enable_thinking": true,
        },
        "name": "Write",
        "enable_all_context_servers": true,
        "tools": {
          "apply_code_action": true,
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "find_path": true,
          "find_references": true,
          "get_code_actions": true,
          "go_to_definition": true,
          "grep": true,
          "list_directory": true,
          "move_path": true,
          "open": true,
          "project_notifications": false,
          "read_file": true,
          "rename_symbol": true,
          "search_web": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
          "update_plan": true,
          "write_file": true,
        },
      },
    },
    "sandbox_permissions": {
      "network_hosts": [
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "gist.github.com",
        "gist.githubusercontent.com",
        "objects.githubusercontent.com",
      ],
    },
    "show_turn_stats": true,
    "thinking_display": "preview",
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "mcp:Context7:get-library-docs": { "default": "allow" },
        "mcp:Context7:query-docs": { "default": "allow" },
        "mcp:Context7:resolve-library-id": { "default": "allow" },
        "mcp:DeepWiki:ask_question": { "default": "allow" },
        "mcp:DeepWiki:read_wiki_contents": { "default": "allow" },
        "mcp:DeepWiki:read_wiki_structure": { "default": "allow" },
        "mcp:Sequential thinking:sequentialthinking": { "default": "allow" },
        "diagnostics": { "default": "allow" },
        "skill": {
          "always_allow": [
            { "pattern": "\\.agents/skills/brainstorming/SKILL\\.md$" },
            {
              "pattern": "\\.agents/skills/dispatching-parallel-agents/SKILL\\.md$",
            },
            { "pattern": "\\.agents/skills/domain-modeling/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/executing-plans/SKILL\\.md$" },
            {
              "pattern": "\\.agents/skills/finishing-a-development-branch/SKILL\\.md$",
            },
            { "pattern": "\\.agents/skills/git-commit/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/grilling/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/grilling-with-docs/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/receiving-code-review/SKILL\\.md$" },
            {
              "pattern": "\\.agents/skills/requesting-code-review/SKILL\\.md$",
            },
            {
              "pattern": "\\.agents/skills/subagent-driven-development/SKILL\\.md$",
            },
            { "pattern": "\\.agents/skills/systematic-debugging/SKILL\\.md$" },
            {
              "pattern": "\\.agents/skills/test-driven-development/SKILL\\.md$",
            },
            { "pattern": "\\.agents/skills/use-semble/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/using-git-worktrees/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/using-superpowers/SKILL\\.md$" },
            {
              "pattern": "\\.agents/skills/verification-before-completion/SKILL\\.md$",
            },
            { "pattern": "\\.agents/skills/writing-plans/SKILL\\.md$" },
            { "pattern": "\\.agents/skills/writing-skills/SKILL\\.md$" },
          ],
        },
        "terminal": {
          "always_allow": [
            { "pattern": "^gh\\s+issue\\s+(list|view|status)(\\s|$)" },
            { "pattern": "^gh\\s+pr\\s+(list|view|status|checks|diff)(\\s|$)" },
            {
              "pattern": "^gh\\s+search\\s+(issues|prs|repos|commits|code)(\\s|$)",
            },
            { "pattern": "^gh\\s+repo\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+run\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+workflow\\s+(list|view)(\\s|$)" },
            { "pattern": "^gh\\s+release\\s+(list|view)(\\s|$)" },
            {
              "pattern": "^gh\\s+project\\s+(list|view|field-list|item-list)(\\s|$)",
            },
            { "pattern": "^gh\\s+ruleset\\s+(list|view|check)(\\s|$)" },
            { "pattern": "^gh\\s+label\\s+list(\\s|$)" },
            { "pattern": "^gh\\s+cache\\s+list(\\s|$)" },
            { "pattern": "^gh\\s+status(\\s|$)" },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+bisect\\s+(log|view|visualize)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+branch(\\s+(--list|-l|-a|--all|-r|--remotes|-v|--verbose|-vv|--show-current|--contains|--no-contains|--merged|--no-merged|--points-at|--format|--column|--no-column|--sort)(\\s|=|$)|\\s*$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(cat-file|rev-parse|rev-list|merge-base|name-rev|count-objects)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(check-ignore|check-attr|check-ref-format|check-mailmap)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+config\\s+(--get|--get-all|--get-regexp|--get-urlmatch|--list|-l|--show-origin|--show-scope|--name-only)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(diff-files|diff-index|diff-tree|diff-pairs|ls-files|ls-tree)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(for-each-ref|show-ref|show-branch|show-index|get-tar-commit-id)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(help|version|--version|var)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(log|show|shortlog|describe|range-diff|whatchanged|cherry)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+notes\\s+(list|show)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+reflog(\\s+(show|exists)(\\s|$)|\\s*$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+remote(\\s+(-v|--verbose|get-url)(\\s|$)|\\s*$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+stash\\s+(list|show)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(status|diff|blame|annotate|grep)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+submodule\\s+(status|summary)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+tag(\\s+(--list|-l|-n|--contains|--no-contains|--merged|--no-merged|--points-at|--format|--column|--sort)(\\s|=|$)|\\s*$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+(verify-pack|verify-commit|verify-tag)(\\s|$)",
            },
            {
              "pattern": "^git(\\s+--no-pager)?\\s+worktree\\s+list(\\s|$)",
            },
            { "pattern": "^rg(\\s|$)" },
          ],
          "always_deny": [
            { "pattern": "^rg\\s+(.*\\s)?--hostname-bin(=|\\s|$)" },
            { "pattern": "^rg\\s+(.*\\s)?--pre(=|\\s|$)" },
          ],
        },
        "thinking": { "default": "allow" },
      },
    },
  },
  "auto_update": false,
  "buffer_font_size": 14,
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_weight": 500.0,
  "calls": {
    "mute_on_join": true,
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "left",
    "default_width": 300.0,
    "button": false,
  },
  "colorize_brackets": true,
  "confirm_quit": true,
  "context_servers": {
    "Context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
    },
    "DeepWiki": {
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "fff": {
      "command": "fff-mcp",
      "args": ["--no-update-check"],
    },
    // Complements Exa: https://docs.parallel.ai/integrations/mcp/search-mcp
    "Parallel": {
      "url": "https://search.parallel.ai/mcp",
    },
    "semble": {
      "command": "uvx",
      "args": ["--from", "semble[mcp]", "semble"],
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp",
    },
    // An MCP server implementation that provides a tool for dynamic and reflective problem-solving through a structured thinking process.
    "Sequential thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
    },
  },
  "cursor_shape": "block",
  "debugger": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "zed",
    "allow_data_collection": "no",
    "disabled_globs": [],
    "mode": "subtle",
  },
  "fast_scroll_sensitivity": 10.0,
  "file_types": {
    "Git Ignore": [".dockerignore", ".prettierignore"],
  },
  "git_panel": {
    "button": false,
    "dock": "left",
    "scrollbar": {
      "show": "system",
    },
    "show_count_badge": true,
    "tree_view": true,
  },
  "hover_popover_delay": 50,
  "icon_theme": {
    "mode": "dark",
    "light": "VSCode Icons for Zed (Dark Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)",
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "active_line_width": 3,
  },
  "languages": {
    "Astro": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "language_servers": ["eslint", "..."],
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
    "Markdown": {
      "format_on_save": "on",
      "language_servers": ["!rumdl", "..."],
      "remove_trailing_whitespace_on_save": false,
      "prettier": {
        "allowed": false,
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "prettier": {
        "allowed": false,
      },
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "templ": "html",
        },
        "experimental": {
          "classRegex": ["class=\"([^\"]*)\"", "className=\"([^\"]*)\""],
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
  },
  "minimap": {
    "show": "auto",
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "project_panel": {
    "button": false,
    "default_width": 300,
    "scrollbar": {
      "show": "system",
    },
    "starts_open": false,
  },
  "redact_private_values": true,
  "scroll_sensitivity": 1.5,
  "search": {
    "button": false,
  },
  "semantic_tokens": "combined",
  "status_bar": {
    "active_language_button": false,
    "cursor_position_button": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "file_icons": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "copy_on_select": true,
  },
  "theme": {
    "mode": "dark",
    "light": "Vercel Light",
    "dark": "Vercel Dark",
  },
  "title_bar": {
    "show_branch_name": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_sign_in": false,
    "show_user_menu": false,
    "show_user_picture": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,
}
